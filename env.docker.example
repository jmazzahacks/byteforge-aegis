# ByteForge Aegis Docker Environment Configuration
# Copy this file to .env when using Docker Compose

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Security Keys (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
MASTER_API_KEY=your-master-api-key-here-generate-with-openssl-rand-hex-32

# Database Configuration (point at your existing Postgres host)
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=aegis
DB_USER=aegis_admin
DB_PASSWORD=your-secure-database-password-here

# Mailgun Configuration
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN=your-mailgun-domain.mailgun.org
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=ByteForge Aegis

# Frontend URL (used for links in verification / password-reset emails)
AEGIS_FRONTEND_URL=https://your-frontend.example.com

# App bind (inside the container)
APP_HOST=0.0.0.0
APP_PORT=5678

# Token Expiration (in seconds)
AUTH_TOKEN_EXPIRATION=3600
EMAIL_VERIFICATION_EXPIRATION=86400
PASSWORD_RESET_EXPIRATION=3600
EMAIL_CHANGE_EXPIRATION=3600

# CORS Configuration
# Use * for all origins (development) or comma-separated list for production
# Example: https://app1.example.com,https://app2.example.com
CORS_ORIGINS=*

# Logging
# DEBUG_LOCAL=true for console logs (local dev), false for Loki shipping (production)
# When DEBUG_LOCAL=false, all LOKI_* variables below are required.
DEBUG_LOCAL=false
LOG_LEVEL=INFO
LOKI_ENDPOINT=
LOKI_USER=
LOKI_PASSWORD=
LOKI_CA_BUNDLE_PATH=/app/certs/loki-ca.pem
